# EcomSePay Environment Template
# Copy this file to .env.local and update with your actual values

# ============ DATABASE ============
# MongoDB connection string
# For local: mongodb://localhost:27017/ecom-sepay
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/ecom-sepay
MONGODB_URI=mongodb://localhost:27017/ecom-sepay

# ============ AUTHENTICATION ============
# JWT secret key for signing tokens (use strong random string in production)
# Generate: openssl rand -base64 32
JWT_SECRET=change-this-to-random-secret-key-in-production

# ============ SEPAY PAYMENT INTEGRATION ============
# SePay API credentials (get from https://sepay.vn)
SEPAY_CLIENT_ID=your-sepay-client-id
SEPAY_API_KEY=your-sepay-api-key
SEPAY_WEBHOOK_SECRET=your-sepay-webhook-secret
SEPAY_API_URL=https://api.sepay.vn

# ============ APPLICATION URLS ============
# API endpoint (used by frontend to make requests)
NEXT_PUBLIC_API_URL=http://localhost:3000

# App public URL (used for redirects, webhooks, etc)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============ ENVIRONMENT ============
# development or production
NODE_ENV=development
